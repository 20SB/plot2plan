generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         String    @default("user")
  createdAt    DateTime  @default(now())
  projects     Project[]
}

model Project {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  plotWidth  Float
  plotHeight Float
  plotUnit   String           @default("ft")
  numFloors  Int              @default(1)
  style      String?
  facing     String?
  vastuScore Float            @default(0)
  rooms      Room[]
  plumbing   PlumbingItem[]
  electrical ElectricalItem[]
  revisions  Revision[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

model Room {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name       String
  type       String
  x          Float
  y          Float
  width      Float
  height     Float
  floor      Int      @default(1)
  direction  String?
  vastuScore Float    @default(0)
  warnings   String[]
}

model PlumbingItem {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String
  x         Float
  y         Float
  floor     Int     @default(1)
  label     String?
}

model ElectricalItem {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String
  x         Float
  y         Float
  floor     Int     @default(1)
  label     String?
}

model Revision {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version       Int
  label         String?
  roomsSnapshot Json
  createdAt     DateTime @default(now())

  @@unique([projectId, version])
}
