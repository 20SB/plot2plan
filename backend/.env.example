# Application
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# Database
MONGODB_URI=mongodb://localhost:27017/house-design-platform

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
